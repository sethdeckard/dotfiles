[core]
  excludesfile = ~/.gitignore_global
  editor = nvim
  pager = delta
[user]
  name = Seth Deckard
  email = seth@deckard.me
[include]
  # supports signingkey and other per-machine config
  path = ~/.gitconfig.inc
[includeIf "gitdir:~/work/"]
  # work-specific settings (override email, etc.)
  path = ~/work/.gitconfig.inc
[advice]
  skippedCherryPicks = false
[diff]
  tool = nvimdiff
  mnemonicPrefix = true
  submodule = diff
[merge]
  tool = nvimdiff
  conflictstyle = zdiff3
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true
  dark = true
  line-numbers = true
  syntax-theme = Solarized (dark)
  file-style = "#f7f779" bold
  file-decoration-style = "#55606b" ul
  hunk-header-style = "#93a1ad" italic
  hunk-header-decoration-style = "#55606b" box
  plus-style = syntax "#0d2818"
  minus-style = syntax "#2c1018"
  plus-emph-style = syntax "#1a4d2e"
  minus-emph-style = syntax "#4d1a2a"
  line-numbers-plus-style = "#35f2ff"
  line-numbers-minus-style = "#ff4d6d"
  line-numbers-zero-style = "#55606b"
  commit-decoration-style = "#f7f779" bold box ul
  commit-style = "#f7f779" bold
[pull]
  ff = only
[push]
  default = simple
  autoSetupRemote = true
[init]
  defaultBranch = main
  templatedir = ~/.git_template
[commit]
  gpgsign = true
[alias]
  aliases = config --get-regexp "^alias\\."
  br = for-each-ref --sort=-committerdate refs/heads/ --format='%(HEAD) %(color:yellow)%(refname:short)%(color:reset) - %(color:red)%(objectname:short)%(color:reset) - %(contents:subject) - %(authorname) (%(color:green)%(committerdate:relative)%(color:reset))'
  brb = for-each-ref --sort=committerdate refs/heads/ --format='%(HEAD) %(color:yellow)%(refname:short)%(color:reset) - %(color:red)%(objectname:short)%(color:reset) - %(contents:subject) - %(authorname) (%(color:green)%(committerdate:relative)%(color:reset))'
  lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%C(bold blue)<%an>%Creset' --abbrev-commit
  lgfix = log --grep="^Fix\\s*" --oneline --decorate
  lgup = log --grep="^Upgrade\\s*" --oneline --decorate
  lga = "log --color --graph --pretty=format:'%C(#ff4d6d)%h%Creset %C(#55606b)//%Creset %s %C(#55606b)// %C(#35f2ff)%an%Creset %C(#f7f779)(%cr)%Creset%C(#ff9f1c)%d%Creset' --abbrev-commit"
  staged = diff --staged
  trash = branch -D
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
