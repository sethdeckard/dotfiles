#!/usr/bin/env bash
# Arasaka HUD -- terminal boot sequence
# Sourced from .zshrc on interactive shell startup

# Guards: skip in non-interactive, VS Code, or nested tmux panes
[[ ! -o interactive ]] 2>/dev/null && [[ $- != *i* ]] && return
[[ "$TERM_PROGRAM" == "vscode" ]] && return
if [[ -n "$TMUX" ]]; then
  # only show in first window, first pane
  tmux_window=$(tmux display-message -p '#I' 2>/dev/null)
  tmux_pane=$(tmux display-message -p '#P' 2>/dev/null)
  [[ "$tmux_window" != "1" || "$tmux_pane" != "1" ]] && return
fi

# Arasaka palette (24-bit ANSI)
_a_yellow="\033[1;38;2;247;247;121m"
_a_cyan="\033[38;2;53;242;255m"
_a_muted="\033[38;2;85;96;107m"
_a_reset="\033[0m"

# Data
_user=$(whoami)
_host=$(hostname -s)
_runtime=$(if [[ "$(uname)" == "Darwin" ]]; then echo "MAC"; else uname -s | tr '[:lower:]' '[:upper:]' | cut -c1-3; fi)
_zsh_ver="${ZSH_VERSION:-$(zsh --version 2>/dev/null | awk '{print $2}')}"
_uptime=""
if [[ "$(uname)" == "Darwin" ]]; then
  _boot=$(sysctl -n kern.boottime 2>/dev/null | awk '{print $4}' | tr -d ',')
  if [[ -n "$_boot" ]]; then
    _now=$(date +%s)
    _secs=$(( _now - _boot ))
    _days=$(( _secs / 86400 ))
    _hours=$(( (_secs % 86400) / 3600 ))
    _mins=$(( (_secs % 3600) / 60 ))
    _uptime="${_days}d ${_hours}h ${_mins}m"
  fi
else
  _uptime=$(uptime -p 2>/dev/null | sed 's/^up //' || uptime | sed 's/.*up *//;s/,.*//')
fi
# On modern macOS, / is the read-only system volume; real user data lives on /System/Volumes/Data
if [[ "$(uname)" == "Darwin" && -d /System/Volumes/Data ]]; then
  _disk=$(df -h /System/Volumes/Data | awk 'NR==2 {print $5 " used"}')
else
  _disk=$(df -h / | awk 'NR==2 {print $5 " used"}')
fi
if [[ "$(uname)" == "Darwin" ]]; then
  _net=$(ipconfig getifaddr en0 2>/dev/null || echo "offline")
else
  _net=$(hostname -I 2>/dev/null | awk '{print $1}')
  [[ -z "$_net" ]] && _net="offline"
fi

# Memory
if [[ "$(uname)" == "Darwin" ]]; then
  # Used = active + wired + compressed (matches Activity Monitor's "Memory Used").
  # Page size is dynamic (4KB on Intel, 16KB on Apple Silicon) — parse from vm_stat header.
  _mem_total=$(sysctl -n hw.memsize 2>/dev/null)
  _vm=$(vm_stat 2>/dev/null)
  _page_size=$(printf '%s\n' "$_vm" | awk '/page size of/ {for(i=1;i<=NF;i++) if($i=="of") {print $(i+1); exit}}')
  _mem_used_pages=$(printf '%s\n' "$_vm" | awk '
    /Pages active/               {gsub(/\./,"",$3); a=$3}
    /Pages wired down/           {gsub(/\./,"",$4); w=$4}
    /Pages occupied by compressor/ {gsub(/\./,"",$5); c=$5}
    END {print a+w+c}
  ')
  if [[ -n "$_mem_used_pages" && "$_mem_used_pages" -gt 0 && -n "$_mem_total" && -n "$_page_size" ]]; then
    _mem_pct=$(( _mem_used_pages * _page_size * 100 / _mem_total ))
    _mem="${_mem_pct}% used"
  else
    _mem="N/A"
  fi
else
  _mem=$(free 2>/dev/null | awk '/^Mem:/ {printf "%.0f%% used", $3/$2*100}')
  [[ -z "$_mem" ]] && _mem="N/A"
fi

# CPU model
if [[ "$(uname)" == "Darwin" ]]; then
  # Apple Silicon has no machdep.cpu.brand_string; fall back to hw.model / system_profiler
  _cpu=$(sysctl -n machdep.cpu.brand_string 2>/dev/null)
  if [[ -z "$_cpu" ]]; then
    _cpu=$(system_profiler SPHardwareDataType 2>/dev/null | awk -F': ' '/Chip/ {print $2; exit}')
  fi
  [[ -z "$_cpu" ]] && _cpu=$(sysctl -n hw.model 2>/dev/null)
  _cpu=$(printf '%s' "$_cpu" | sed 's/(R)//g;s/(TM)//g;s/  */ /g' | cut -c1-30)
else
  _cpu=$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | sed 's/^ *//;s/(R)//g;s/(TM)//g' | cut -c1-30)
fi
[[ -z "$_cpu" ]] && _cpu="UNKNOWN"

# Box inner width = 49 (matching the 49 dashes in the border)
# Every line: │ + 49 visible chars + │
_W=49

# Pad a string to exactly $_W chars
_pad() { printf "%-${_W}s" "$1"; }

# Colored box line: │ <content padded to _W> │
_boxline() {
  printf "%b%s%b\n" "${_a_muted}│${_a_reset}" "$1" "${_a_muted}│${_a_reset}"
}

# Data row: "  LABEL:     value                              "
_row() {
  local label="$1" value="$2"
  local plain
  plain=$(printf "  %-11s%s" "$label" "$value")
  local padded
  padded=$(_pad "$plain")
  # Re-apply color to the label and value portions within the padded string
  # Positions: 2 spaces, 11 chars label, rest is value (padded)
  local label_padded value_padded
  label_padded=$(printf "%-11s" "$label")
  value_padded="${padded:13}"
  printf "%b  %b%b%b\n" \
    "${_a_muted}│${_a_reset}" \
    "${_a_muted}${label_padded}${_a_reset}" \
    "${_a_cyan}${value_padded}${_a_reset}" \
    "${_a_muted}│${_a_reset}"
}

printf "\n"
for _scan_msg in "SCANNING SUBSYSTEMS..." "AUTHENTICATING NODE..." "LINK ESTABLISHED."; do
  printf "\r  %b%s%b" "${_a_muted}" "$_scan_msg" "${_a_reset}"
  sleep 0.08
done
printf "\r%-40s\r" ""
printf "%b\n" "${_a_muted}┌$(printf '%0.s─' $(seq 1 $_W))┐${_a_reset}"
_host_upper=$(echo "$_host" | tr '[:lower:]' '[:upper:]')
_header=$(_pad " SYS INIT // ${_host_upper}")
printf "%b%b%b\n" "${_a_muted}│${_a_reset}" "${_a_yellow}${_header}${_a_reset}" "${_a_muted}│${_a_reset}"
_boxline "$(_pad "")"
_row "OPERATOR:" "$_user"
_row "HOST:" "$_host"
_row "RUNTIME:" "$_runtime // zsh $_zsh_ver"
_row "UPTIME:" "$_uptime"
_row "DISK:" "$_disk"
_row "NET:" "$_net"
_row "MEM:" "$_mem"
_row "CPU:" "$_cpu"
printf "%b\n" "${_a_muted}└$(printf '%0.s─' $(seq 1 $_W))┘${_a_reset}"
printf "\n"
