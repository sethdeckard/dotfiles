# Arasaka HUD -- zsh-syntax-highlighting color overrides
# Sourced after oh-my-zsh loads the zsh-syntax-highlighting plugin

ZSH_HIGHLIGHT_STYLES[command]='fg=#4da6ff,bold'
ZSH_HIGHLIGHT_STYLES[builtin]='fg=#35f2ff,bold'
ZSH_HIGHLIGHT_STYLES[alias]='fg=#35f2ff'
ZSH_HIGHLIGHT_STYLES[function]='fg=#4da6ff'
ZSH_HIGHLIGHT_STYLES[unknown-token]='fg=#ff4d6d,bold'
ZSH_HIGHLIGHT_STYLES[reserved-word]='fg=#ff9f1c,bold'
ZSH_HIGHLIGHT_STYLES[single-quoted-argument]='fg=#f7f779'
ZSH_HIGHLIGHT_STYLES[double-quoted-argument]='fg=#f7f779'
ZSH_HIGHLIGHT_STYLES[dollar-quoted-argument]='fg=#f7f779'
ZSH_HIGHLIGHT_STYLES[path]='fg=#93a1ad,underline'
ZSH_HIGHLIGHT_STYLES[globbing]='fg=#ff9f1c'
ZSH_HIGHLIGHT_STYLES[comment]='fg=#55606b'
ZSH_HIGHLIGHT_STYLES[arg0]='fg=#4da6ff,bold'
ZSH_HIGHLIGHT_STYLES[default]='fg=#93a1ad'
